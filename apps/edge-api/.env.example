APP_NAME="Boarding Face Validation - Edge API"
APP_VERSION="0.1.0"
ENVIRONMENT="local"
DEBUG=true
LOG_LEVEL="INFO"

# Identifies this vehicle to the central API during sync (matches the
# device_id the sync-worker will use against /sync/pull|push|ack).
BUS_ID="bus-01"

DATABASE_URL="postgresql+asyncpg://postgres:postgres@postgres-edge:5432/boarding_edge"

# Local (on-bus) vision-service instance — NOT the central one. In this
# docker-compose dev setup both central-api and edge-api point at the same
# shared container; in production each bus runs its own.
VISION_SERVICE_URL="http://vision-service:8002"
VISION_SERVICE_TIMEOUT_SECONDS=10.0

# Matching / decision thresholds — mirror central-api's so a passenger
# enrolled centrally behaves consistently once synced to the edge.
MIN_FACE_QUALITY_SCORE=0.5
MAX_SIMILARITY_DISTANCE=0.4

# Used by the offline-detection heuristic in health checks: how long the
# central API has to respond before we consider the bus "offline".
CENTRAL_API_URL="http://central-api:8000"
CENTRAL_API_PING_TIMEOUT_SECONDS=2.0

# Origins allowed to call this API from a browser (operator-web tablet).
# In production add the bus tablet's LAN IP: "http://192.168.1.10:5174"
CORS_ORIGINS='["http://localhost:5174","http://127.0.0.1:5174"]'
