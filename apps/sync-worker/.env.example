APP_NAME="Boarding Face Validation - Sync Worker"
APP_VERSION="0.1.0"
ENVIRONMENT="local"
DEBUG=true
LOG_LEVEL="INFO"

# Same bus identity edge-api uses — this worker is meant to run as a
# sidecar process for one specific bus, sharing its local Postgres.
BUS_ID="bus-01"

# Same physical database edge-api writes to (local_passengers,
# local_face_embeddings, local_tickets, local_validation_logs). The worker
# is the only writer for the cache tables and the only one who flips
# synced_at on validation logs.
DATABASE_URL="postgresql+asyncpg://postgres:postgres@postgres-edge:5432/boarding_edge"

CENTRAL_API_URL="http://central-api:8000"
CENTRAL_API_TIMEOUT_SECONDS=10.0

# Must match central-api's EDGE_SYNC_API_KEY — sent as the X-Device-Key
# header on every /sync/* call (RF06/RF10/RF11).
EDGE_SYNC_API_KEY="change-me-edge-sync-key"

# How often a full pull+push cycle runs. RNF01's 2s budget is about the
# boarding-validation hot path on edge-api, not this worker — this only
# needs to be frequent enough that the operator dashboard doesn't show a
# stale "pending sync" count for too long.
SYNC_INTERVAL_SECONDS=10
