APP_NAME="Boarding Face Validation - Central API"
APP_VERSION="0.1.0"
ENVIRONMENT="local"
DEBUG=true

DATABASE_URL="postgresql+asyncpg://postgres:postgres@postgres-central:5432/boarding_central"

LOG_LEVEL="INFO"

# Auth / JWT (admin-web login)
JWT_SECRET_KEY="colocar_uma_chave_bem_longa_e_aleatoria_com_32_bytes_ou_mais"
JWT_ALGORITHM="HS256"
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Shared secret edge devices send via the X-Device-Key header on /sync/*
EDGE_SYNC_API_KEY="change-me-edge-sync-key"

# Vision Service integration
VISION_SERVICE_URL="http://vision-service:8002"
VISION_SERVICE_TIMEOUT_SECONDS=10.0

# Biometrics / facial recognition tuning
EMBEDDING_DIMENSIONS=512
MIN_FACE_QUALITY_SCORE=0.5
MAX_SIMILARITY_DISTANCE=0.4