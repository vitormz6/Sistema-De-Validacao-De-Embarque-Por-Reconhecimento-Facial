APP_NAME="Boarding Face Validation - Vision Service"
APP_VERSION="0.1.0"
ENVIRONMENT="local"
DEBUG=true
LOG_LEVEL="INFO"

# insightface model pack. "buffalo_l" bundles SCRFD (detection) + ArcFace
# (recognition); downloaded automatically into MODEL_ROOT on first use.
MODEL_PACK_NAME="buffalo_l"
MODEL_ROOT="/app/.insightface"

# -1 = CPU, 0 = first GPU (requires onnxruntime-gpu instead of the CPU
# build declared in pyproject.toml).
CTX_ID=-1

DET_SIZE_WIDTH=640
DET_SIZE_HEIGHT=640
DET_THRESH=0.5

# Quality scoring tuning (see app/pipeline/quality.py)
MIN_FACE_SIZE_RATIO=0.05
BLUR_VARIANCE_REFERENCE=120.0
BRIGHTNESS_MIN=40.0
BRIGHTNESS_MAX=215.0

# Basic liveness heuristic tuning (see app/pipeline/liveness.py)
LIVENESS_MIN_SHARPNESS_VARIANCE=15.0
LIVENESS_FREQ_PEAK_RATIO_THRESHOLD=0.05
