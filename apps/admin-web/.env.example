# Browser-facing URL for central-api — must be reachable from the host
# running the browser, not the docker-compose service name (the browser
# doesn't sit inside the compose network). In the dev compose setup,
# central-api publishes 8000 on the host, so this is correct as-is even
# when admin-web itself runs inside its own container.
VITE_API_BASE_URL="http://localhost:8000"
