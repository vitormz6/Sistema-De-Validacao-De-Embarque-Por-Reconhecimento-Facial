# Same reasoning as admin-web's .env.example: this is read by the
# BROWSER running on the operator's tablet, not by a container inside
# the docker-compose network, so it must be a reachable host:port, not
# the compose service name `edge-api`.
#
# In production each bus's tablet would point this at that bus's own
# edge-api instance (e.g. http://<bus-onboard-ip>:8001) — there's no
# single shared edge-api once buses stop sharing a dev docker-compose.
VITE_EDGE_API_BASE_URL="http://localhost:8001"
